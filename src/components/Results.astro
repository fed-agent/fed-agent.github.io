      r('Local · 21', [43.9, 20.9, 51.4, 15.1, 40.7, 30.5, 35.0, 73.9, 45.6], 'local'),
      r('Local · 42', [40.0, 50.8, 23.9, 15.6, 10.4, 30.5, 27.7, 73.9, 35.6], 'local'),
      r('Local · 84', [37.5, 49.6, 41.6, 45.2, 38.2, 24.9, 39.5, 50.0, 34.3], 'local'),
      r('Centralized', [91.0, 80.9, 71.6, 48.2, 64.1, 32.0, 68.3, 75.4, 63.7], 'central'),

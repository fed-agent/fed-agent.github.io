      r('Local · 42', [50.0, 37.5, 76.9, 25.0, 42.9, 14.3, 45.3, 75.1, 53.1], 'local'),
      r('Local · 84', [50.0, 37.5, 46.2, 25.0, 28.6, 0.0, 34.4, 72.7, 47.7], 'local'),
      r('Centralized', [64.3, 37.5, 69.2, 50.0, 42.9, 28.6, 51.6, 79.9, 57.8], 'central'),

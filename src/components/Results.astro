---
// Results.astro: figures + GRPO/PPO performance table (original style)
import ChartBlock from './ChartBlock.astro';
const cols = ['Pick', 'Look', 'Clean', 'Heat', 'Cool', 'Pick2', 'All', 'Score', 'Succ.'];
const models = ['Qwen2.5-1.5B-Instruct', 'Qwen2.5-3B-Instruct', 'Qwen2.5-7B-Instruct', 'Llama-3.2-3B-Instruct'];
const r = (m, vals, kind) => ({ m, vals, kind });
const data = {
  grpo: {
    'Qwen2.5-1.5B-Instruct': [

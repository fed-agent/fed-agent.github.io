      r('Centralized', [94.1, 80.0, 64.3, 42.9, 50.0, 22.2, 62.5, 86.0, 63.9], 'central'),
      r('FedAgent', [95.5, 62.5, 49.7, 47.5, 85.3, 45.1, 65.2, 85.5, 63.1], 'fed'),
    ],
    'Qwen2.5-7B-Instruct': [
      r('Local · 21', [35.5, 25.0, 61.0, 25.9, 35.8, 45.2, 38.4, 70.9, 49.2], 'local'),
      r('Local · 42', [29.0, 45.0, 18.8, 25.6, 15.9, 38.0, 42.1, 85.2, 33.6], 'local'),
      r('Local · 84', [34.7, 47.5, 44.4, 51.3, 40.1, 21.8, 35.7, 60.6, 39.3], 'local'),
      r('Centralized', [93.7, 82.5, 71.5, 47.9, 63.2, 31.9, 73.3, 78.8, 64.7], 'central'),
      r('FedAgent', [94.5, 85.0, 56.0, 62.5, 86.7, 42.8, 75.5, 89.0, 68.9], 'fed'),
    ],
    'Llama-3.2-3B-Instruct': [
      r('Local · 21', [39.8, 50.0, 17.9, 40.0, 20.7, 34.0, 38.1, 65.3, 50.5], 'local'),
      r('Local · 42', [18.2, 55.0, 41.9, 34.3, 41.0, 25.0, 35.0, 67.0, 51.0], 'local'),
      r('Local · 84', [29.9, 32.5, 39.0, 18.9, 18.8, 37.6, 29.7, 70.2, 55.7], 'local'),
      r('Centralized', [72.4, 62.5, 59.3, 45.2, 53.7, 27.9, 54.9, 76.3, 56.2], 'central'),
      r('FedAgent', [83.7, 57.5, 60.6, 55.9, 65.3, 24.9, 61.2, 74.4, 57.8], 'fed'),
    ],
  },
  ppo: {
    'Qwen2.5-1.5B-Instruct': [
      r('Local · 21', [37.8, 16.9, 36.0, 37.8, 21.6, 20.8, 28.1, 77.5, 54.0], 'local'),
      r('Local · 42', [38.9, 35.1, 52.6, 13.2, 32.7, 22.9, 34.1, 69.4, 54.0], 'local'),
      r('Local · 84', [60.4, 36.8, 34.9, 15.5, 23.6, 6.5, 28.6, 71.5, 45.8], 'local'),
      r('Centralized', [61.9, 38.3, 72.5, 53.1, 42.9, 28.3, 49.3, 79.0, 55.5], 'central'),
      r('FedAgent', [81.9, 76.7, 54.1, 39.3, 83.3, 50.3, 64.9, 83.3, 60.1], 'fed'),
    ],

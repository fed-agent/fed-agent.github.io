<style>
  .leaderboard-container {
    margin: 2rem 0;
  }

  .table-controls {
    margin-bottom: 1.5rem;
    text-align: center;
  }

  .model-legend {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #555;
  }

  .legend-color {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #ddd;
  }

  .local-legend {
    background-color: #f8f9fa;
  }

  .centralized-legend {
    background-color: #fff5f0;
  }

  .fedagent-legend {
    background-color: #eef4ff;
  }

  .model-group {
    margin-bottom: 2rem;
  }

  .model-group-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #2a2f6c;
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
    border-left: 4px solid #2a2f6c;
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: 10px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    background: white;
  }

  .leaderboard-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .leaderboard-table th {
    background: linear-gradient(135deg, #2a2f6c, #3a4b8e);
    color: white;
    padding: 0.7rem 0.5rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.85rem;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
  }

  .leaderboard-table th:last-child {
    border-right: none;
  }

  .header-alfworld {
    background: linear-gradient(135deg, #3a5a8e, #4a6b9e) !important;
  }

  .header-webshop {
    background: linear-gradient(135deg, #5a3a8e, #6b4a9e) !important;
  }

  .sub-header {
    background: linear-gradient(135deg, #4a5b8e, #5a6b9e) !important;
    font-size: 0.8rem !important;
    padding: 0.5rem 0.4rem !important;
  }

  .highlighted-col {
    background: linear-gradient(135deg, #2a4f6c, #3a6080) !important;
  }

  .leaderboard-table td {
    padding: 0.6rem 0.5rem;
    text-align: center;
    border-bottom: 1px solid #f0f0f0;
    font-size: 0.88rem;
  }

  .model-name {
    text-align: left !important;
    font-weight: 500;
    color: #333;
    white-space: nowrap;
  }

  .local-model {
    background-color: #f8f9fa;
  }

  .local-model:hover {
    background-color: #e9ecef;
  }

  .centralized-model {
    background-color: #fff5f0;
  }

  .centralized-model:hover {
    background-color: #ffe6d9;
  }

  .fedagent-model {
    background-color: #eef4ff;
    font-weight: 500;
  }

  .fedagent-model:hover {
    background-color: #ddeaff;
  }

  .best-score {
    background-color: rgba(42, 47, 108, 0.15);
    font-weight: 700;
    color: #1e2a5f;
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    .leaderboard-table {
      font-size: 0.8rem;
    }

    .leaderboard-table th,
    .leaderboard-table td {
      padding: 0.5rem 0.3rem;
    }

    .model-name {
      font-size: 0.75rem;
    }

    .model-legend {
      flex-direction: column;
      align-items: center;
      gap: 0.6rem;
    }
  }
</style>

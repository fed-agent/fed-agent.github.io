---
// Hero.astro - FedAgent project hero section
---
<section id="hero" class="content-section hero-section">
  <div class="title-wrapper">
    <div class="logo-title-row">
      <img src="/logo.png" alt="FedAgent Logo" class="title-logo" />
      <span class="project-name" id="animated-name">FedAgent</span>
    </div>
    <h1 class="main-subtitle-line">
      <span id="animated-title" class="subtitle-text">Federated Agent Reinforcement Learning</span>
    </h1>
  </div>

  <div class="resources-section">
    <div class="resources-buttons">
      <a href="#" class="resource-button">
        <i class="fas fa-archive resource-icon"></i>
        <span>arXiv (coming soon)</span>
      </a>
      <a href="/pdf/FedAgent.pdf" class="resource-button" target="_blank">
        <i class="fas fa-file-alt resource-icon"></i>
        <span>Paper (PDF, earlier version)</span>
      </a>
      <a href="https://github.com/fed-agent" class="resource-button">
        <i class="fab fa-github resource-icon"></i>
        <span>Code (coming soon)</span>
      </a>
    </div>
  </div>

  <div class="teaser-figure">
    <img
      class="teaser-image"
      src="/figures/fedagent_figure.png"
      alt="FedAgent Framework Overview"
    />
  </div>

  <div class="authors-section">
    <div class="authors-list">
      <p class="author-line">
        <a href="https://canyuchen.com/">Canyu Chen<sup class="affiliation-marker">1*</sup></a>,
        <a href="https://scholar.google.com/citations?user=55J-zgwAAAAJ&hl=en">Kangyu Zhu<sup class="affiliation-marker">2*</sup></a>,
        <a href="https://billchan226.github.io/">Zhaorun Chen<sup class="affiliation-marker">3</sup></a>,
        <a href="https://scholar.google.com/citations?user=SbACfYQAAAAJ">Zhanhui Zhou<sup class="affiliation-marker">4</sup></a>,
        <a href="https://shizhediao.github.io/">Shizhe Diao<sup class="affiliation-marker">5</sup></a>
      </p>
      <p class="author-line">
        <a href="https://2prime.github.io/">Yiping Lu<sup class="affiliation-marker">1</sup></a>,
        <a href="https://litian96.github.io/">Tian Li<sup class="affiliation-marker">3</sup></a>,
        <a href="https://limanling.github.io/">Manling Li<sup class="affiliation-marker">1&dagger;</sup></a>,
        <a href="https://dawnsong.io/">Dawn Song<sup class="affiliation-marker">4&dagger;</sup></a>

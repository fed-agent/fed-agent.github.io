---
// Heterogeneity.astro: two-level agent heterogeneity (original style)
import DistBlock from './DistBlock.astro';
const taskTypes = [
  { name: 'Preference', q: 'What type?', measure: '\\Delta^2_{\\text{pref}}=\\tfrac1N\\sum_i\\lVert p_i-\\bar p\\rVert_2^2', algo: 'PreferencePartition(ω)', id: 'dist-pref', note: 'Type marginal across categories, i.e. which task-conditional behaviors the mixture exercises.', toggles: [{ dist: 'preference_webshop', key: 's1', label: 'ω=0.99' }, { dist: 'preference_webshop', key: 's0', label: 'ω=0.01' }] },
  { name: 'Coverage', q: 'How many?', measure: '\\Delta^2_{\\text{cov}}=\\widehat{\\mathrm{CV}}^2(\\{n_i\\})', algo: 'CoveragePartition(ξ)', id: 'dist-cov', note: 'Per-client pool size, which sets per-epoch exploration breadth under with-replacement RL sampling.', toggles: [{ dist: 'coverage', key: 's0', label: 'ξ=1' }, { dist: 'coverage', key: 's1', label: 'ξ=256' }] },
  { name: 'Hardness', q: 'How hard?', measure: '\\Delta^2_{\\text{hard}}=\\widehat{\\mathrm{Var}}_i(\\rho_i)', algo: "HardnessPartition(ξ')", id: 'dist-hard', note: 'Thresholded success rate, which controls the policy-gradient advantage signal each client receives.', toggles: [{ dist: 'hardness', key: 's0', label: "ξ′=1" }, { dist: 'hardness', key: 's1', label: "ξ′=256" }] },
];
const envVariants = [
  { name: 'Catalog Split', stage: 'content', sev: 'B' },
  { name: 'Field-Subset Index', stage: 'encoding', sev: 'C' },
  { name: 'BM25 Reweighting', stage: 'matching', sev: 'C' },
  { name: 'Lookalike Injection', stage: 'content + matching', sev: 'D' },
  { name: 'Rank Wrapper', stage: 'rendering', sev: 'D' },
];
---
<section id="heterogeneity" class="content-section">
  <div class="section-container">
    <h2 class="section-title">Two-Level Agent Heterogeneity</h2>
    <p class="section-description">
      The asymmetry organizes how clients differ along two structurally distinct levels: what the
      policy <span class="robustness-text">observes</span> (the task) and what it
      <span class="fragility-text">cannot</span> (the environment).
    </p>

    <!-- Task level -->
    <h3 class="level-title"><span class="lvl-pill robust-pill">Observable</span> Task-level: what clients ask</h3>
    <p class="level-desc">Three operationally separable sub-types, each isolated by a single dispersion knob (D1 to D4: one knob each, other measures and all first-order means held fixed). Distributions below are simulated from the partition algorithms across 100 clients.</p>
    <div class="task-grid">
      {taskTypes.map((t) => (
        <div class="task-card">
          <div class="task-card-head"><span class="task-name">{t.name}</span><span class="task-q">{t.q}</span></div>
          <div class="task-measure" set:html={`$$${t.measure}$$`} />
          <DistBlock toggles={t.toggles} id={t.id} height={200} />
          <p class="task-note">{t.note}</p>
          <div class="task-algo">{t.algo}</div>
        </div>
      ))}
    </div>

    <!-- Env level -->
    <h3 class="level-title env-level-title"><span class="lvl-pill fragile-pill">Implicit</span> Environment-level: which world the agent acts in</h3>
    <p class="level-desc">A transition kernel couples action to next observation through four stages; perturbing any stage yields a distinct form of environment heterogeneity. Five WebShop variants span the spectrum.</p>
    <div class="pipeline">
      {['content', 'encoding', 'matching', 'rendering'].map((s, i) => (
        <>
          <span class="pipe-stage">{s}</span>
          {i < 3 && <span class="pipe-arrow">→</span>}
        </>
      ))}
    </div>
    <div class="env-grid">
      {envVariants.map((v) => (
        <div class={`env-card env-${v.sev.toLowerCase()}`}>
          <div class="env-card-head"><span class="env-name">{v.name}</span><span class={`env-sev sev-${v.sev.toLowerCase()}`}>Pattern {v.sev}</span></div>
          <span class="env-stage">{v.stage}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .robustness-text { color: #2e7d32; font-weight: 700; }
  .fragility-text { color: #c62828; font-weight: 700; }

  .level-title { font-size: 1.4rem; font-weight: 700; color: #2a2f6c; text-align: center; margin: 1.5rem 0 0.5rem; display: flex; align-items: center; justify-content: center; gap: 0.6rem; flex-wrap: wrap; }
  .env-level-title { margin-top: 3rem; }
  .lvl-pill { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.25rem 0.7rem; border-radius: 20px; }
  .robust-pill { background: #e8f5e9; color: #2e7d32; }
  .fragile-pill { background: #fde7ea; color: #c62828; }
  .level-desc { text-align: center; color: #555; font-size: 1rem; line-height: 1.6; max-width: 760px; margin: 0 auto 1.6rem; }

  .task-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.3rem; }
  .task-card { background: #fff; border: 1px solid #e8e8e8; border-radius: 12px; padding: 1.4rem; box-shadow: 0 3px 12px rgba(0,0,0,0.05); display: flex; flex-direction: column; }
  .task-card-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 0.4rem; }
  .task-name { font-size: 1.2rem; font-weight: 700; color: #2a2f6c; }
  .task-q { font-style: italic; color: #2e7d32; font-size: 0.95rem; }
  .task-measure { text-align: center; margin: 0.3rem 0 0.7rem; overflow-x: auto; }
  .task-card .chart-card { border: none; box-shadow: none; padding: 0; background: transparent; }
  .task-card .chart-controls { margin-bottom: 0.6rem; }
  .task-card .seg-btn { padding: 0.3rem 0.7rem; font-size: 0.8rem; }
  .task-card .chart-caption { display: none; }
  .task-note { font-size: 0.9rem; color: #555; line-height: 1.5; margin: 0.8rem 0; flex-grow: 1; }
  .task-algo { align-self: flex-start; font-family: 'Courier New', monospace; font-size: 0.78rem; font-weight: 600; color: #4a56c9; background: #eef2ff; border-radius: 20px; padding: 0.3rem 0.8rem; }

  .pipeline { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.4rem; }
  .pipe-stage { background: #fff; border: 1px solid #ef9a9a; color: #c62828; font-weight: 600; font-size: 0.9rem; padding: 0.4rem 1rem; border-radius: 20px; text-transform: capitalize; }
  .pipe-arrow { color: #c62828; font-weight: 700; }

  .env-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; }
  .env-card { background: #fff; border: 1px solid #e8e8e8; border-radius: 10px; padding: 1.1rem; border-top: 4px solid #ccc; }
  .env-b { border-top-color: #2e9e6a; } .env-c { border-top-color: #e0a93a; } .env-d { border-top-color: #d2564a; }
  .env-card-head { display: flex; align-items: center; justify-content: space-between; gap: 0.4rem; margin-bottom: 0.4rem; }
  .env-name { font-size: 0.98rem; font-weight: 700; color: #2a2f6c; }
  .env-sev { font-size: 0.68rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 20px; white-space: nowrap; }
  .sev-b { background: #e8f5e9; color: #2e7d32; } .sev-c { background: #fdf3e1; color: #8a610c; } .sev-d { background: #fde7ea; color: #c62828; }
  .env-stage { font-family: 'Courier New', monospace; font-size: 0.78rem; color: #888; }

  @media (max-width: 768px) { .task-grid { grid-template-columns: 1fr; } }
</style>

---
// Theory.astro - Convergence bound and σ²-dominance theory (KaTeX rendered)

// Define LaTeX strings in frontmatter to avoid Astro parsing {} as JSX
const eq_main = String.raw`$$\frac{1}{T}\sum_{t=0}^{T-1} \mathbb{E}\|\nabla J(\theta_t)\|^2 \;\leq\; \underbrace{\mathcal{O}\!\left(\frac{\sigma^2}{MT\tau}\right)}_{\color{#2e7d32}{\text{(I) Stochastic noise}}} \;+\; \underbrace{\mathcal{O}\!\left(\tau^2 L^2 \delta_{\text{data}}^2\right)}_{\color{#1565c0}{\text{(II) Task-level drift}}} \;+\; \underbrace{\mathcal{O}\!\left(\tau^2 L^2 \delta_{\text{env}}^2\right)}_{\color{#c62828}{\text{(III) Env-level drift}}}$$`;

const sym_sigma = String.raw`$\sigma^2$`;
const sym_delta_data = String.raw`$\delta_{\text{data}}^2$`;
const sym_delta_env = String.raw`$\delta_{\text{env}}^2$`;
const sym_arrow_inf = String.raw`$\;\rightarrow\; \infty$`;

const title_sigma = String.raw`$\sigma^2$-Dominance Theory`;
const desc_sigma = String.raw`In LLM agent settings, the exponential action space makes gradient noise $\sigma^2$ enormous. This has a surprising consequence:`;
---

<section id="theory" class="content-section alt-background">
  <div class="section-container">
    <h2 class="section-title">Theoretical Analysis</h2>
    <p class="section-description">Why is FedAgent robust to task heterogeneity but fragile to environment heterogeneity?</p>

    <!-- Convergence Bound -->
    <div class="theory-block">
      <h3 class="theory-title">Convergence Bound</h3>
      <p class="theory-description">
        We derive a convergence bound for FedAgent that decomposes the optimization error into three interpretable terms:
      </p>
      <div class="equation-box">
        <div class="equation-main" set:html={eq_main} />
      </div>

      <div class="terms-grid">
        <div class="term-card noise-card">
          <div class="term-symbol-katex" set:html={sym_sigma} />
          <div class="term-name">Gradient Noise</div>
          <div class="term-desc">How noisy is each gradient?</div>
        </div>
        <div class="term-card task-card">
          <div class="term-symbol-katex" set:html={sym_delta_data} />
          <div class="term-name">Task Divergence</div>
          <div class="term-desc">How different are clients' tasks?</div>
        </div>
        <div class="term-card env-card">
          <div class="term-symbol-katex" set:html={sym_delta_env} />
          <div class="term-name">Env Divergence</div>
          <div class="term-desc">How different are clients' worlds?</div>
        </div>
      </div>
    </div>

    <!-- σ²-Dominance Theory -->
    <div class="theory-block">
      <h3 class="theory-title" set:html={title_sigma} />
      <p class="theory-description" set:html={desc_sigma} />

      <div class="dominance-table">
        <div class="dominance-row noise-row">
          <div class="dom-left">
            <div class="dom-symbol-katex noise-katex" set:html={sym_sigma} />
            <div class="dom-label">Gradient Noise</div>
          </div>
          <div class="dom-bar">
            <div class="bar-fill noise-fill"></div>
          </div>
          <div class="dom-right">
            <strong>Enormous</strong> &mdash; exponential action space
          </div>
        </div>

        <div class="dominance-row task-row">
          <div class="dom-left">
            <div class="dom-symbol-katex task-katex" set:html={sym_delta_data} />
            <div class="dom-label">Bounded Task Divergence</div>
          </div>
          <div class="dom-bar">
            <div class="bar-fill task-fill"></div>
          </div>
          <div class="dom-right">
            <strong>Absorbed by noise.</strong>
          </div>
        </div>

        <div class="dominance-row env-row">
          <div class="dom-left">
            <div class="dom-symbol-katex env-katex" set:html={sym_delta_env} />
            <div class="dom-label">Unbounded Env Divergence</div>
          </div>
          <div class="dom-bar">
            <div class="bar-fill env-fill"></div>
          </div>
          <div class="dom-right" set:html={`<strong>Systematic conflict.</strong> Not absorbed. ${sym_arrow_inf}`} />
        </div>
      </div>

      <div class="insight-box">
        <strong>Key Insight:</strong> Intrinsic <span class="robustness-text">Robustness</span> against Task Heterogeneity.
        Fragility towards <span class="fragility-text">Environment Heterogeneity</span>.
      </div>
    </div>

  </div>
</section>

<style>
  .theory-block {
    margin-bottom: 2.5rem;
    padding: 2rem;
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.06);
    border: 1px solid #f0f0f0;
  }

  .theory-title {
    font-size: 1.35rem;
    font-weight: 700;
    color: #2a2f6c;
    margin-bottom: 0.75rem;
  }

  .theory-description {
    font-size: 1rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 800px;
  }

  /* Equation box */
  .equation-box {
    background: #f8f9fc;
    border: 1px solid #e0e4ef;
    border-radius: 10px;
    padding: 1.5rem 1.5rem;
    margin-bottom: 2rem;
    text-align: center;
    overflow-x: auto;
  }

  .equation-main {
    font-size: 1.1rem;
    line-height: 2.2;
  }

  /* Terms grid */
  .terms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .term-card {
    padding: 1.25rem;
    border-radius: 10px;
    text-align: center;
    border: 2px solid;
  }

  .noise-card { background: #f1f8e9; border-color: #aed581; }
  .task-card { background: #e3f2fd; border-color: #90caf9; }
  .env-card { background: #fce4ec; border-color: #ef9a9a; }

  .term-symbol-katex {
    font-size: 1.5rem;
    margin-bottom: 0.4rem;
  }

  .noise-card .term-symbol-katex :global(.katex) { color: #2e7d32; }
  .task-card .term-symbol-katex :global(.katex) { color: #1565c0; }
  .env-card .term-symbol-katex :global(.katex) { color: #c62828; }

  .term-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 0.3rem;
  }

  .term-desc {
    font-size: 0.85rem;
    color: #666;
  }

  /* Dominance table */
  .dominance-table {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .dominance-row {
    display: grid;
    grid-template-columns: 200px 1fr 250px;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    background: #fafafa;
  }

  .dom-left {
    text-align: center;
  }

  .dom-symbol-katex {
    font-size: 1.25rem;
  }

  .noise-katex :global(.katex) { color: #2e7d32; }
  .task-katex :global(.katex) { color: #1565c0; }
  .env-katex :global(.katex) { color: #c62828; }

  .dom-label {
    font-size: 0.8rem;
    color: #666;
    margin-top: 0.15rem;
  }

  .dom-bar {
    height: 28px;
    background: #e9ecef;
    border-radius: 6px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    border-radius: 6px;
    transition: width 1s ease;
  }

  .noise-fill {
    width: 95%;
    background: linear-gradient(90deg, #4caf50, #2e7d32);
  }

  .task-fill {
    width: 8%;
    background: linear-gradient(90deg, #64b5f6, #1565c0);
  }

  .env-fill {
    width: 55%;
    background: linear-gradient(90deg, #ef5350, #c62828);
  }

  .dom-right {
    font-size: 0.92rem;
    color: #444;
    line-height: 1.4;
  }

  /* Insight box */
  .insight-box {
    background: linear-gradient(135deg, #f5f7ff, #eef2ff);
    border: 2px solid #c5cae9;
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    font-size: 1.05rem;
    line-height: 1.6;
    text-align: center;
  }

  .robustness-text {
    color: #2e7d32;
    font-weight: 700;
  }

  .fragility-text {
    color: #c62828;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .theory-block {
      padding: 1.25rem;
    }

    .terms-grid {
      grid-template-columns: 1fr;
    }

    .dominance-row {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .dom-bar {
      height: 20px;
    }

    .equation-main {
      font-size: 0.9rem;
    }
  }
</style>

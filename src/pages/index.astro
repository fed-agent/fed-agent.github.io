---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Asymmetry from '../components/Asymmetry.astro';
import Method from '../components/Method.astro';
import Heterogeneity from '../components/Heterogeneity.astro';
import Mechanism from '../components/Mechanism.astro';
import Results from '../components/Results.astro';
import AuthorsCitation from '../components/AuthorsCitation.astro';

const pageTitle = 'FedAgent · Is Decentralized LLM Agent RL Robust to Heterogeneity?';
---
<Layout title={pageTitle}>
  <Hero />
  <Asymmetry />
  <Method />
  <Heterogeneity />
  <Mechanism />
  <Results />
  <AuthorsCitation />
</Layout>

<script>
  // Mobile dropdown toggle for the header "More Research" menu
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.dropdown-toggle');
    const dropdown = document.querySelector('.dropdown');
    if (toggle && dropdown) {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        dropdown.classList.toggle('open');
      });
      document.addEventListener('click', (e) => {
        if (!dropdown.contains(e.target as Node)) dropdown.classList.remove('open');
      });
    }
  });
</script>

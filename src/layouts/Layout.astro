---
// src/layouts/Layout.astro
import '../styles/global.css';
import '../styles/charts.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title } = Astro.props;
const SITE = 'https://fed-agent.github.io';
const DESC = 'FedAgent (Federated Agent Reinforcement Learning) trains LLM agents across distributed clients without sharing data. Its robustness is asymmetric: robust to task-level heterogeneity, worst-case fragile to environment-level heterogeneity, explained by the Input-Dynamics Asymmetry of task-augmented MDPs.';
const OG_IMG = `${SITE}/social-preview.png`;
const PAPER_TITLE = 'Is Decentralized LLM Agent RL Robust to Heterogeneity? An Asymmetric Tale';
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <script is:inline>document.documentElement.classList.add('js')</script>
        <meta name="description" content={DESC} />
        <meta name="keywords" content="federated learning, reinforcement learning, AI agents, LLM agents, GRPO, PPO, privacy-preserving machine learning, decentralized training, heterogeneity, WebShop, ALFWorld, input-dynamics asymmetry" />
        <meta name="author" content="Canyu Chen, Kangyu Zhu, Zhaorun Chen, Zhanhui Zhou, Shizhe Diao, Yiping Lu, Tian Li, Manling Li, Dawn Song" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#2a2f6c" />
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <link rel="icon" type="image/png" href="/icon.png" />
        <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/manifest.webmanifest" />
        <link rel="canonical" href="https://fed-agent.github.io/" />
        <meta name="generator" content={Astro.generator} />
        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={`FedAgent: ${PAPER_TITLE}`} />
        <meta property="og:description" content={DESC} />
        <meta property="og:image" content={OG_IMG} />
        <meta property="og:url" content="https://fed-agent.github.io/" />
        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={`FedAgent: ${PAPER_TITLE}`} />
        <meta name="twitter:description" content={DESC} />
        <meta name="twitter:image" content={OG_IMG} />
        <!-- Google Scholar -->
        <meta name="citation_title" content={PAPER_TITLE} />
        <meta name="citation_author" content="Chen, Canyu" />
        <meta name="citation_author" content="Zhu, Kangyu" />
        <meta name="citation_author" content="Chen, Zhaorun" />
        <meta name="citation_author" content="Zhou, Zhanhui" />
        <meta name="citation_author" content="Diao, Shizhe" />
        <meta name="citation_author" content="Lu, Yiping" />
        <meta name="citation_author" content="Li, Tian" />
        <meta name="citation_author" content="Li, Manling" />
        <meta name="citation_author" content="Song, Dawn" />
        <meta name="citation_publication_date" content="2026" />
        <meta name="citation_pdf_url" content="https://fed-agent.github.io/pdf/FedAgent.pdf" />
        <meta name="robots" content="index, follow" />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css">
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js"></script>
        <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js"
          onload="renderMathInElement(document.body, {delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}],throwOnError:false});"></script>
        <!-- Structured Data -->
        <script type="application/ld+json" is:inline set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "ScholarlyArticle",
          "headline": PAPER_TITLE,
          "description": DESC,
          "image": OG_IMG,
          "url": "https://fed-agent.github.io/",
          "datePublished": "2026",
          "author": [
            {"@type": "Person", "name": "Canyu Chen", "url": "https://canyuchen.com/"},
            {"@type": "Person", "name": "Kangyu Zhu"},
            {"@type": "Person", "name": "Zhaorun Chen", "url": "https://billchan226.github.io/"},
            {"@type": "Person", "name": "Zhanhui Zhou"},
            {"@type": "Person", "name": "Shizhe Diao", "url": "https://shizhediao.github.io/"},
            {"@type": "Person", "name": "Yiping Lu", "url": "https://2prime.github.io/"},
            {"@type": "Person", "name": "Tian Li", "url": "https://litian96.github.io/"},
            {"@type": "Person", "name": "Manling Li", "url": "https://limanling.github.io/"},
            {"@type": "Person", "name": "Dawn Song", "url": "https://dawnsong.io/"}
          ],
          "publisher": {"@type": "Organization", "name": "MLL Lab, Northwestern University", "url": "https://www.mll.lab.northwestern.edu/"}
        })} />
    </head>
    <body>
        <Header />
        <main>
            <slot />
        </main>
        <Footer />
        <script>
          import '../scripts/chartClient.ts';
        </script>
        <!-- Statcounter -->
        <script type="text/javascript" is:inline>
        var sc_project=13215024;
        var sc_invisible=1;
        var sc_security="6e9958ed";
        </script>
        <script type="text/javascript" src="https://www.statcounter.com/counter/counter.js" async is:inline></script>
        <noscript><div class="statcounter"><a title="Web Analytics" href="https://statcounter.com/" target="_blank"><img class="statcounter" src="https://c.statcounter.com/13215024/0/6e9958ed/1/" alt="Web Analytics" referrerpolicy="no-referrer-when-downgrade" /></a></div></noscript>
    </body>
</html>

<style is:global>
	:root {
		--header-height: 60px;
		--page-max-width: 1100px;
		--text-light: #555;
	}
	* { box-sizing: border-box; margin: 0; padding: 0; }
	html {
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		color: #252525;
		scroll-behavior: smooth;
	}
	body { min-height: 100vh; overflow-x: hidden; }
	main { padding-top: var(--header-height); }
</style>
